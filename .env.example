# Gemini API Key (obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# FastAPI Backend Configs
SECRET_KEY=some_secure_secret_key_string
ALGORITHM=HS256

# Local Database URL (when running locally outside Docker)
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/mini_crm
